---
import ToolPage from '../layouts/ToolPage.astro';
---
<ToolPage
  title="Study Buddy"
  titleHtml='Study <span class="brand-mark">Buddy</span>'
  tagline="An open-source AI personal tutor that runs entirely on your computer — private by design, bring your own model."
  description="An open-source AI personal tutor that runs entirely on your computer — private by design, bring your own model."
  brand="study-buddy"
  repo="michael-borck/study-buddy"
>

<section class="app-section">
  <h2>What it does</h2>
  <div class="app-features">
    <div class="app-feature">
      <h3>Topic in, tutor out</h3>
      <p>Type any topic and pick an education level from elementary through graduate.</p>
    </div>
    <div class="app-feature">
      <h3>Grounded teaching</h3>
      <p>Searches the web, reads real sources, and teaches from them — not from memory alone.</p>
    </div>
    <div class="app-feature">
      <h3>Interactive quizzes</h3>
      <p>Conversational follow-ups and quiz-style prompts to check your understanding as you go.</p>
    </div>
    <div class="app-feature">
      <h3>Bring your own notes</h3>
      <p>Paste in slides, excerpts, or your own materials and the tutor will work them in.</p>
    </div>
    <div class="app-feature">
      <h3>Local or cloud</h3>
      <p>Use Ollama for fully offline tutoring, or plug in OpenAI, Anthropic, Google, or Groq.</p>
    </div>
    <div class="app-feature">
      <h3>Fresh every session</h3>
      <p>No persistent knowledge base. Each session is fast, focused, and forgettable by design.</p>
    </div>
  </div>
</section>

<section class="app-section">
  <h2>How it works</h2>
  <div class="app-steps">
    <div class="app-step">
      <h3>Type a topic</h3>
      <p>Pick the subject and the education level you want the tutor to pitch the explanation at.</p>
    </div>
    <div class="app-step">
      <h3>It searches the web</h3>
      <p>Study Buddy queries DuckDuckGo, fetches the most relevant pages, and reads them.</p>
    </div>
    <div class="app-step">
      <h3>It summarises &amp; grounds</h3>
      <p>Sources are condensed to fit your model's context window, then handed to the tutor.</p>
    </div>
    <div class="app-step">
      <h3>You learn &amp; quiz</h3>
      <p>The tutor explains, asks follow-ups, and adapts to where you're stuck.</p>
    </div>
  </div>
</section>

</ToolPage>
