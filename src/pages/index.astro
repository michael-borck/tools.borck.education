---
import { readdirSync } from 'node:fs';
import { join } from 'node:path';
import Base from '../layouts/Base.astro';
import { tools, goals, audSections, spotlightIds } from '../data/tools';

const titleCase = (id: string) => id.split('-').map(w => w[0].toUpperCase() + w.slice(1)).join(' ');

const PALETTE = ['#0e7490', '#7c3aed', '#b45309', '#047857', '#be123c', '#4f46e5', '#0f766e', '#c2410c'];
const hue = (id: string) => PALETTE[[...id].reduce((a, c) => a + c.charCodeAt(0), 0) % PALETTE.length];
const monogram = (id: string) => id.split('-').map(w => w[0]).join('').slice(0, 2).toUpperCase();

const normType = (t: string) =>
  /web/i.test(t) ? 'Web app' : /cli|python/i.test(t) ? 'Command line' : 'Desktop app';

// Screenshot auto-discovery, same convention as ToolPage: public/screenshots/<id>-1.<ext>
let shotFiles: string[] = [];
try {
  shotFiles = readdirSync(join(process.cwd(), 'public', 'screenshots'));
} catch { /* no screenshots dir */ }
const shot = (id: string) => {
  const f = shotFiles.find(f => new RegExp(`^${id}-1\\.(png|jpe?g|webp|gif|avif)$`).test(f));
  return f ? `/screenshots/${f}` : null;
};

// Primary click target: the app's own landing page, else the guide page, else GitHub.
const link = (t: any) => t.web || t.page || t.github || '#';
const isExternal = (t: any) => link(t) !== t.page;

const byGoal = (key: string) => tools.filter(t => t.tags.includes(key));
const stubs = tools.filter(t => t.tags.length === 0);

const spotlight = spotlightIds
  .map(id => tools.find(t => t.id === id))
  .filter(Boolean)
  .map(t => ({
    id: t!.id,
    name: titleCase(t!.id),
    desc: t!.shortDesc,
    href: link(t!),
    external: isExternal(t!),
    shot: shot(t!.id),
  }));
---
<Base title="tools.borck.education — AI tools for educators">

<div class="topbar">
  <a href="/" class="topbar-logo">Michael Borck · <strong>Teaching Tools</strong></a>
  <div class="topbar-spacer"></div>
  <nav class="topbar-links">
    <a href="https://borck.education" title="Tools, books, and teaching for educators and students">Education</a>
    <a href="https://research.borck.dev" title="Academic research, papers, and HCI work">Research</a>
    <a href="https://resume.borck.dev" title="CV in 10 formats from a single YAML data source">Resume</a>
    <a href="https://github.com/michael-borck">GitHub</a>
    <a href="https://borck.dev/">borck.dev</a>
  </nav>
</div>

<main class="home">

  <!-- Hero: copy left, spotlight slider right -->
  <div class="home-hero-row">
    <div class="home-hero-copy">
      <h1>Free, private AI tools for your classroom</h1>
      <p>Built by an educator, for educators. Everything runs on your machine or in your
         browser — your students' work never leaves your hands. No accounts, no cost, no catch.</p>
      <div class="home-trust">
        <span>🔒 Private by design</span><span>💸 Free forever</span><span>🧑‍🏫 Made for teaching</span>
      </div>
    </div>

    <div class="home-spot" id="home-spot">
      {spotlight.map((s, i) => (
        <a class={`home-slide ${i === 0 ? 'active' : ''}`} href={s.href}
           target={s.external ? '_blank' : undefined} rel={s.external ? 'noopener' : undefined}>
          {s.shot
            ? <img class="home-slide-img" src={s.shot} alt={`${s.name} screenshot`} loading={i === 0 ? 'eager' : 'lazy'} />
            : <div class="home-slide-tile" style={`background:linear-gradient(135deg, ${hue(s.id)}, ${hue(s.id)}b0)`}>
                <span>{monogram(s.id)}</span>
              </div>}
          <div class="home-slide-cap">
            <div class="home-kicker">Spotlight</div>
            <h2>{s.name}</h2>
            <p>{s.desc}</p>
          </div>
        </a>
      ))}
      {spotlight.length > 1 && (
        <div class="home-spot-dots">
          {spotlight.map((s, i) => (
            <button type="button" class={i === 0 ? 'active' : ''} aria-label={`Show ${s.name}`}></button>
          ))}
        </div>
      )}
    </div>
  </div>

  <div class="home-filter-row">
    <input class="home-search" id="home-search" type="search" placeholder="Search tools…" autocomplete="off" />
  </div>

  {audSections.map(sec => (
    <div class="home-aud-section" id={`for-${sec.aud}`}>
      <div class="home-aud-head">
        <h2>{sec.title}</h2>
        <p>{sec.sub}</p>
      </div>
      {goals.filter(g => g.aud === sec.aud && byGoal(g.key).length > 0).map(g => (
        <div class="home-shelf-wrap" id={g.key}>
          <div class="home-shelf-head">
            <h3>{g.label}</h3>
            <p>{g.blurb}</p>
          </div>
          <div class="home-shelf">
            {byGoal(g.key).map(t => (
              <div class="home-mini" data-name={titleCase(t.id).toLowerCase()} data-desc={t.shortDesc.toLowerCase()}>
                <a class="home-mini-main" href={link(t)} aria-label={titleCase(t.id)}
                   target={isExternal(t) ? '_blank' : undefined} rel={isExternal(t) ? 'noopener' : undefined}>
                  {shot(t.id)
                    ? <div class="home-mini-shot"><img src={shot(t.id)} alt="" loading="lazy" /></div>
                    : <div class="home-mini-mono" style={`background:${hue(t.id)}`}>{monogram(t.id)}</div>}
                  <div class="home-mini-body">
                    <h4>{titleCase(t.id)}</h4>
                    <p>{t.shortDesc}</p>
                    <span class="home-mini-type">{normType(t.type)}</span>
                  </div>
                </a>
                <div class="home-mini-links">
                  {t.web && t.page && <a class="home-mini-guide" href={t.page} title={`${titleCase(t.id)} guide`}>Guide</a>}
                  {t.github && (
                    <a class="home-mini-gh" href={t.github} target="_blank" rel="noopener" title={`${titleCase(t.id)} on GitHub`} aria-label={`${titleCase(t.id)} on GitHub`}>
                      <svg viewBox="0 0 16 16" width="15" height="15" fill="currentColor" aria-hidden="true"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27s1.36.09 2 .27c1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8Z"/></svg>
                    </a>
                  )}
                </div>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  ))}

  <div class="home-rest" id="everything-else">
    <h2>Everything else</h2>
    <p>Utilities, experiments and building blocks — mostly for the technically inclined.</p>
    <div class="home-rest-grid">
      {stubs.map(t => (
        <a class="home-rest-item" href={t.github || '#'} target="_blank" rel="noopener"
           data-name={titleCase(t.id).toLowerCase()} data-desc={t.shortDesc.toLowerCase()}>
          <strong>{titleCase(t.id)}</strong>
          <span>{t.shortDesc}</span>
        </a>
      ))}
    </div>
  </div>

  <div class="home-no-results hidden" id="home-no-results">
    No tools match that search — try another term.
  </div>

  <footer class="site-footer">
    <p>Michael Borck · Perth, WA · <a href="mailto:hello@borck.dev">hello@borck.dev</a> · <a href="https://borck.dev">borck.dev</a></p>
  </footer>
</main>

</Base>

<script>
  // ── Spotlight rotation ──
  const spot = document.getElementById('home-spot');
  if (spot) {
    const slides = [...spot.querySelectorAll('.home-slide')];
    const dots = [...spot.querySelectorAll('.home-spot-dots button')];
    if (slides.length > 1) {
      let cur = 0;
      let timer: ReturnType<typeof setInterval> | null = null;
      const go = (n: number) => {
        slides[cur].classList.remove('active'); dots[cur]?.classList.remove('active');
        cur = (n + slides.length) % slides.length;
        slides[cur].classList.add('active'); dots[cur]?.classList.add('active');
      };
      const spin = () => {
        if (matchMedia('(prefers-reduced-motion: reduce)').matches) return;
        timer = setInterval(() => go(cur + 1), 6000);
      };
      const stop = () => { if (timer) clearInterval(timer); };
      dots.forEach((d, n) => d.addEventListener('click', e => { e.preventDefault(); stop(); go(n); spin(); }));
      spot.addEventListener('mouseenter', stop);
      spot.addEventListener('mouseleave', spin);
      spin();
    }
  }

  // ── Search (shareable via ?q=) ──
  const searchEl = document.getElementById('home-search') as HTMLInputElement | null;
  function applySearch(q: string) {
    const query = q.trim().toLowerCase();
    document.querySelectorAll<HTMLElement>('.home-mini, .home-rest-item').forEach(el => {
      el.classList.toggle('hidden', !!query && !`${el.dataset.name} ${el.dataset.desc}`.includes(query));
    });
    document.querySelectorAll('.home-shelf-wrap').forEach(w => {
      const items = [...w.querySelectorAll('.home-mini')];
      w.classList.toggle('hidden', !items.some(el => !el.classList.contains('hidden')));
    });
    document.querySelectorAll('.home-aud-section').forEach(sec => {
      const shelves = [...sec.querySelectorAll('.home-shelf-wrap')];
      sec.classList.toggle('hidden', shelves.every(s => s.classList.contains('hidden')));
    });
    const rest = document.getElementById('everything-else');
    const restItems = [...document.querySelectorAll('.home-rest-item')];
    rest?.classList.toggle('hidden', !restItems.some(el => !el.classList.contains('hidden')));
    const anyVisible = document.querySelector('.home-mini:not(.hidden), .home-rest-item:not(.hidden)');
    document.getElementById('home-no-results')?.classList.toggle('hidden', !!anyVisible);

    const url = new URL(location.href);
    if (query) url.searchParams.set('q', q.trim());
    else url.searchParams.delete('q');
    history.replaceState(null, '', url);
  }
  if (searchEl) {
    searchEl.addEventListener('input', () => applySearch(searchEl.value));
    const initial = new URLSearchParams(location.search).get('q');
    if (initial) { searchEl.value = initial; applySearch(initial); }
  }
</script>
