---
import { readdirSync } from 'node:fs';
import { join } from 'node:path';
import Base from './Base.astro';

interface Props {
  title: string;
  titleHtml: string;
  tagline: string;
  description: string;
  brand: string;
  repo: string;
}
const { title, titleHtml, tagline, description, brand, repo } = Astro.props;

// Auto-discover screenshots for this tool: public/screenshots/<brand>-<n>.<ext>,
// sorted numerically. Drop in a new file and rebuild — the carousel picks it up.
let shots: string[] = [];
try {
  const re = new RegExp(`^${brand}-\\d+\\.(png|jpe?g|webp|gif|avif)$`);
  shots = readdirSync(join(process.cwd(), 'public', 'screenshots'))
    .filter(f => re.test(f))
    .sort((a, b) => a.localeCompare(b, undefined, { numeric: true }))
    .map(f => `/screenshots/${f}`);
} catch { /* no screenshots dir — hero renders without a carousel */ }
---
<Base title={`${title} — borck.education`} description={description}>

<!-- Embed detection: hides topbar + back when loaded in an iframe via ?embed=1 -->
<script is:inline>
  if (new URLSearchParams(window.location.search).has('embed')) {
    document.documentElement.classList.add('embedded');
  }
</script>

<!-- Topbar (hidden when embedded) -->
<div class="topbar">
  <a href="/" class="topbar-logo">
    <span>borck</span><span class="dot">.</span><span class="edu">education</span>
  </a>
  <div class="topbar-spacer"></div>
  <nav class="topbar-links">
    <a href="/">← All tools</a>
    <a href="https://github.com/michael-borck">GitHub</a>
    <a href="https://borck.dev/">borck.dev</a>
  </nav>
</div>

<div class="tool-scroll-wrap">
  <div class="app-page" data-brand={brand}>

    <div class:list={['app-hero', { 'has-carousel': shots.length > 0 }]}>
      <div class="hero-copy">
        <h1 set:html={titleHtml} />
        <p class="app-tagline">{tagline}</p>
        <div class="app-download" data-repo={repo}></div>
      </div>
      {shots.length > 0 && (
        <div class="hero-carousel" data-carousel>
          <div class="carousel-frame">
            {shots.map((src, i) => (
              <img
                src={src}
                alt={`${title} screenshot ${i + 1}`}
                class={i === 0 ? 'active' : ''}
                loading={i === 0 ? 'eager' : 'lazy'}
              />
            ))}
          </div>
          {shots.length > 1 && (
            <div class="carousel-dots">
              {shots.map((_, i) => (
                <button
                  type="button"
                  class={i === 0 ? 'active' : ''}
                  aria-label={`Show screenshot ${i + 1}`}
                ></button>
              ))}
            </div>
          )}
        </div>
      )}
    </div>

    <slot />

    <div class="app-back">
      <a href="/">← Back to all tools</a>
    </div>

  </div>
</div>

</Base>

<script src="/app-landing.js" is:inline></script>

<script is:inline>
  document.querySelectorAll('[data-carousel]').forEach((carousel) => {
    const imgs = [...carousel.querySelectorAll('.carousel-frame img')];
    const dots = [...carousel.querySelectorAll('.carousel-dots button')];
    if (imgs.length < 2) return;

    let current = 0;
    let timer = null;

    function show(n) {
      imgs[current].classList.remove('active');
      dots[current]?.classList.remove('active');
      current = (n + imgs.length) % imgs.length;
      imgs[current].classList.add('active');
      dots[current]?.classList.add('active');
    }

    const reduceMotion = matchMedia('(prefers-reduced-motion: reduce)').matches;
    function start() {
      if (reduceMotion) return;
      timer = setInterval(() => show(current + 1), 5000);
    }
    function stop() { clearInterval(timer); }

    dots.forEach((dot, n) => dot.addEventListener('click', () => { stop(); show(n); start(); }));
    carousel.addEventListener('mouseenter', stop);
    carousel.addEventListener('mouseleave', start);
    start();
  });
</script>
